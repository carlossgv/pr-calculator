POSTGRES_DB=prcalc
POSTGRES_USER=prcalc
POSTGRES_PASSWORD=prcalc

# Local Docker Compose database URL.
DATABASE_URL=postgresql://prcalc:prcalc@db:5432/prcalc?schema=public

# Web defaults used by the local stack.
VITE_APP_ENV=dev
VITE_APP_TITLE=PR Calculator Dev
VITE_APP_VERSION=local
VITE_API_BASE=http://localhost:3001
VITE_DEBUG_SYNC=0
VITE_DEBUG_HTTP=0
VITE_DEBUG_IDENTITY=0
